# X/Twitter API Credentials
# Get these from https://developer.twitter.com/en/portal/dashboard
#
# IMPORTANT: The bookmarks endpoint REQUIRES OAuth 2.0 Authorization Code
# with PKCE (User Context). OAuth 1.0a and Bearer Token (App-Only) will NOT work.
#
# 1. Create/select a Project & App in the Developer Portal
# 2. Go to your App settings → "User authentication settings" → Set up
# 3. Enable OAuth 2.0 Authorization Code with PKCE
# 4. Set the redirect URL to: http://127.0.0.1:6006/callback
# 5. Save, then copy your Client ID from the "Keys and Tokens" tab

# REQUIRED: OAuth 2.0 Client ID
TWITTER_CLIENT_ID=your_client_id_here

# OPTIONAL: Client Secret (only needed for confidential apps)
# TWITTER_CLIENT_SECRET=your_client_secret_here

# OPTIONAL: Redirect URI (default: http://127.0.0.1:6006/callback)
# Must match what you configured in your App settings
# REDIRECT_URI=http://127.0.0.1:6006/callback

# Optional: Customize output directory (default: output)
# OUTPUT_DIR=output

# Optional: Customize state file location (default: .archive_state.json)
# STATE_FILE=.archive_state.json

# Optional: Customize OAuth token file location (default: .x_token.json)
# TOKEN_FILE=.x_token.json