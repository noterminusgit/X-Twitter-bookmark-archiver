# X (Twitter) API Credentials
# Get these from https://developer.x.com/en/portal/dashboard

# API Key and Secret (Consumer Key/Secret) — required
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here

# Access Token and Secret — required
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_secret_here

# Optional: Customize output directory (default: output)
# OUTPUT_DIR=output

# Optional: Customize state file location (default: .archive_state.json)
# STATE_FILE=.archive_state.json

# Optional: Comma-separated output formats (default: markdown,images,videos)
# Available: markdown, pdf, images, videos
# OUTPUT_FORMATS=markdown,images,videos

# Optional: Path to a scraped bookmarks JSON file from the Chrome extension.
# Tweets listed here are skipped during API processing (already DOM-captured).
# SCRAPED_BOOKMARKS_FILE=scraped_bookmarks.json