# Twitter/X API Credentials
# Get these from https://developer.twitter.com/en/portal/dashboard

# Bearer Token for OAuth 2.0
TWITTER_BEARER_TOKEN=your_bearer_token_here

# API Key and Secret (Consumer Key/Secret)
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here

# Access Token and Secret
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_secret_here

# Optional: Customize output directory (default: output)
# OUTPUT_DIR=output

# Optional: Customize state file location (default: .archive_state.json)
# STATE_FILE=.archive_state.json
